PORT=5000
# If you change PORT, set VITE_API_PORT in client/.env to the same value (see client/.env.example).

# =============================================================================
# MongoDB — use Atlas (cloud) OR local
# =============================================================================
#
# --- Option A: MongoDB Atlas (recommended) ---
# 1. atlas.mongodb.com → your project → Database → Connect → Drivers.
# 2. Copy the URI. It looks like:
#    mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
# 3. Set MONGODB_URI (preferred) or MONGO_URI to that string, with:
#    - Your real username and password instead of placeholders.
#    - If the password has @ # : etc., URL-encode them (e.g. @ → %40, # → %23).
#    - A database name at the end of the path, e.g. ...mongodb.net/inventoryDB
#    - Optional query params Atlas suggests, e.g.
#      ?retryWrites=true&w=majority
#
# Example (fake host — replace with yours from Atlas):
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abc12.mongodb.net/inventoryDB?retryWrites=true&w=majority
# MONGO_URI=...   # optional alias; same as MONGODB_URI if MONGODB_URI is unset
#
# 4. Atlas → Network Access: add your current IP, or 0.0.0.0/0 for testing (not for production).
# 5. Atlas → Database Access: user must have read/write on this cluster (Atlas “Built-in Role”
#    “Read and write to any database” is fine for a single-app cluster).
#
# --- Option B: Local MongoDB ---
# MONGODB_URI=mongodb://127.0.0.1:27017/balaji_inventory
#
MONGODB_URI=mongodb://127.0.0.1:27017/balaji_inventory

# =============================================================================
# Auth
# =============================================================================
# JWT signing (required in production). You can use SESSION_SECRET instead;
# if JWT_SECRET is unset, SESSION_SECRET is used when present.
JWT_SECRET=replace-with-a-long-random-string
# SESSION_SECRET=replace-with-a-long-random-string

# Used ONLY until someone uses "Change password" in the app.
# After that, the password is stored in MongoDB and .env is ignored for login.
ADMIN_PASSWORD=password1234

# =============================================================================
# Deploy on Render.com (or similar)
# =============================================================================
# Do NOT commit real passwords or secrets to git. Use the host "Environment" UI.
# Render: Web Service → Environment → Environment Variables:
#
#   MONGO_URI          = mongodb+srv://USER:PASSWORD@cluster....mongodb.net/inventoryDB?retryWrites=true&w=majority
#                      (URL-encode special chars in PASSWORD, e.g. # → %23)
#   SESSION_SECRET     = long random string (used as JWT if JWT_SECRET is unset)
#   JWT_SECRET         = optional; overrides SESSION_SECRET for JWT when set
#   ADMIN_PASSWORD     = first-time admin login until "Change password" is used
#   NODE_ENV           = production
#
# Render sets PORT automatically — leave PORT unset on Render unless required.
#
# Suggested service settings:
#   Root directory: server
#   Build command:  npm install
#   Start command:  npm start
#
# Atlas → Network Access: allow connections from the internet (0.0.0.0/0) for dev, or
# lock down per Render docs for production.
